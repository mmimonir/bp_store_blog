{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.1.2",
        "blendbyte/paypal": "^1.0",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3.1",
        "laravel/socialite": "^5.26.1",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.6.3",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-newsletter": "^5.3.2",
        "unisharp/laravel-filemanager": "^2.13.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/boost": "^2.0",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^12.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Touhidurabir\\Filterable\\": "packages/laravel-filterable/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "13.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
